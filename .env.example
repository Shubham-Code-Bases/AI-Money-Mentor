# AI-MoneyMentor — Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# News API Key (get from https://newsapi.org)
NEWS_API_KEY=your_news_api_key_here

# Database URL (MySQL — optional, app works without it)
# Format: mysql+pymysql://username:password@host/dbname
DATABASE_URL=mysql+pymysql://root:@localhost/aimoneymentor
